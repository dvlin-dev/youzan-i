{
  "name": "jxc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node --env-file=.env.local --env-file=.env node_modules/vitest/vitest.mjs run tests/query-sql.integration.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push --force",
    "db:seed": "tsx --env-file=.env.local --env-file=.env lib/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@openai/agents": "^0.11.6",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "openai": "^6.39.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
